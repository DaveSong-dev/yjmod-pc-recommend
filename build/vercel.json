{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/shipping-submit.js": {
      "maxDuration": 60
    },
    "api/shipping-public.js": {
      "maxDuration": 15
    },
    "api/revive-product.js": {
      "maxDuration": 60
    },
    "api/soldout-log.js": {
      "maxDuration": 15
    },
    "api/admin-auth.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://www.youngjaecomputer.com https://youngjaecomputer.com;"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/data/reco/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=600"
        }
      ]
    }
  ]
}
